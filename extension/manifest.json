{
  "manifest_version": 3,
  "name": "Meet Transcript",
  "version": "1.0.0",
  "description": "Real-time transcript: join Meet, click Start, see transcript in the panel",
  "permissions": ["tabCapture", "offscreen", "storage", "scripting", "tabs"],
  "host_permissions": ["http://127.0.0.1:8000/*", "ws://localhost:*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["utils.js", "helper.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}